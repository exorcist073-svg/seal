# LLM (at least one)
ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

PORT=3001

# RPC + SEAL proxy (same network as frontend wallet)
RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=

# Optional: required for POST /api/pipeline-onchain, /api/chain/* writes, disputes
# SIGNER_PRIVATE_KEY=

# Lit: network only (no API key for encrypt/decrypt — uses Ethereum signing).
# Default if unset: nagaDev. Examples: nagaDev, nagaTest, nagaMainnet
LIT_NETWORK=nagaDev
# Optional — Lit Auth Service HTTP routes only (x-api-key), e.g. payment delegation
# LIT_API_KEY=

# Storacha / w3up — real IPFS CIDs for sealed blobs
# Generate principal + try delegation:  npm run storacha:setup
# https://docs.storacha.network/ai/quickstart/ — Mg… private key + delegation --base64
# Agent principal (from `storacha key create`), NOT the public did:key line alone:
# STORACHA_PRINCIPAL=
# UCAN delegation string (or use STORACHA_PROOF_FILE=./.storacha/proof.txt)
# STORACHA_PROOF=
# STORACHA_PROOF_FILE=
# STORACHA_PRINCIPAL_FILE=
