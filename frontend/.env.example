NEXT_PUBLIC_SEAL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Lit Naga network — must match backend LIT_NETWORK (e.g. nagaDev)
# NEXT_PUBLIC_LIT_NETWORK=nagaDev
# Omit NEXT_PUBLIC_SEAL_API_URL to call /api and /health on the same origin (Next rewrites → backend).
# Optional: SEAL_API_PROXY_TARGET=http://127.0.0.1:3001 (default) in .env.local for the dev server.
# Or set a direct URL: NEXT_PUBLIC_SEAL_API_URL=http://127.0.0.1:3001 (must match backend PORT)

# Ethereum Sepolia (11155111) — same RPC you use for deploy/backend reads
# NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/...

# Local Anvil: set true + run anvil + deploy contract (see docs/operator-local.md)
# NEXT_PUBLIC_USE_LOCAL_CHAIN=true
# NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
